# ──────────────────────────────────────────────────────────────────────────────
# Pulse — Environment Variables
#
# Copy to .env and fill in values.
# Lines marked [required] must be set for the app to start.
# Lines marked [local dev] have sensible defaults for local development.
# Lines marked [production] are only needed in deployed environments.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# [local dev] defaults match docker-compose.dev.yml — no changes needed
POSTGRES_USER="pulse"
POSTGRES_PASSWORD="pulse"
POSTGRES_DB="pulse"
DATABASE_URL="postgresql://pulse:pulse@localhost:5432/pulse?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# [required] Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# [required] Must match your app's origin
# Local dev: http://localhost:5173
# Production: https://pulse.emmabyte.io
BETTER_AUTH_URL="http://localhost:5173"

# [optional] Comma-separated list of additional trusted origins for auth
# Needed when the app is accessed from a different origin than BETTER_AUTH_URL
# e.g. behind a reverse proxy, Cloudflare Tunnel, or during e2e tests
BETTER_AUTH_TRUSTED_ORIGINS=""

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# [required] Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origin: http://localhost:5173 (local) or https://pulse.emmabyte.io (prod)
# Authorized redirect URI:      http://localhost:5173/api/auth/callback/google (local)
#                                https://pulse.emmabyte.io/api/auth/callback/google (prod)
# If left empty, Google OAuth is disabled and only email/password login works.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Webhook Secrets (optional env fallbacks) ─────────────────────────────────
# Can also be configured in the admin UI at /admin/settings.
# Values set in the UI take priority over env vars.
MAILERSEND_WEBHOOK_SECRET=""
VERCEL_WEBHOOK_SECRET=""

# ─── Notification Channels ────────────────────────────────────────────────────
# Alert notification channels (MailerSend, SMTP, Slack, ClickUp) are configured
# entirely through the admin UI at /admin/settings. No env vars needed.

# ─── Cloudflare Tunnel ───────────────────────────────────────────────────────
# [production] Not needed for local dev — only used by docker-compose.yml
CLOUDFLARE_TUNNEL_TOKEN=""

# ─── Container Registry ─────────────────────────────────────────────────────
# [production] Docker image reference used by docker-compose.yml
# GHCR (default):  ghcr.io/emmabyte/pulse:latest
# Docker Hub:      emmabyteeng/pulse:latest
DOCKER_IMAGE="ghcr.io/emmabyte/pulse:latest"

# [production] Only needed if using Docker Hub private images
DOCKERHUB_USERNAME=""
DOCKERHUB_TOKEN=""

# ─── Cloudflare R2 Backups ──────────────────────────────────────────────────
# [production] Used by backup/restore scripts for cloud database backups
# Create an R2 bucket + API token at https://dash.cloudflare.com → R2
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="pulse-backups"

# ─── App ──────────────────────────────────────────────────────────────────────
PUBLIC_APP_NAME="Pulse"
PUBLIC_APP_URL="http://localhost:5173"
NODE_ENV="development"

# Set to "true" on first deploy to seed default alert rules
SEED_DB="false"
