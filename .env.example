# Database (docker-compose constructs DATABASE_URL from these)
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse

# For local dev without docker-compose:
DATABASE_URL="postgresql://pulse:pulse@localhost:5432/pulse?schema=public"

# Auth
BETTER_AUTH_SECRET="change-me-to-a-random-secret"
BETTER_AUTH_URL="http://localhost:5173"

# Webhook Secrets
MAILERSEND_WEBHOOK_SECRET=""
VERCEL_WEBHOOK_SECRET=""

# Cloudflare Tunnel (production)
CLOUDFLARE_TUNNEL_TOKEN=""

# App
PUBLIC_APP_NAME="Pulse"
PUBLIC_APP_URL="http://localhost:5173"
NODE_ENV="development"

# Set to "true" on first deploy to seed alert rules
SEED_DB="false"
